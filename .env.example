# TripProof 로컬 실행 설정
#
# 실제 product flow는 Supabase vector retrieval backend를 사용합니다.
# Supabase URL과 service role key를 채운 뒤 서버를 시작합니다.
TRIPPROOF_RETRIEVAL_BACKEND=supabase

# Supabase retrieval backend 설정
TRIPPROOF_SUPABASE_URL=
TRIPPROOF_SUPABASE_SERVICE_ROLE_KEY=
TRIPPROOF_SUPABASE_INSERT_BATCH_SIZE=100
TRIPPROOF_SUPABASE_REST_TIMEOUT_SECONDS=6.0

# 임베딩 설정
TRIPPROOF_EMBEDDING_PROVIDER=ollama
TRIPPROOF_EMBEDDING_MODEL=nomic-embed-text-v2-moe
TRIPPROOF_EMBEDDING_DIMENSIONS=768
TRIPPROOF_EMBEDDING_AUTO_GENERATE=1
TRIPPROOF_OLLAMA_BASE_URL=http://localhost:11434
TRIPPROOF_OLLAMA_EMBEDDING_TIMEOUT_SECONDS=2.0

# 체크인 fact 후보 생성 설정
TRIPPROOF_FACT_PROPOSER_BACKEND=ollama
TRIPPROOF_OLLAMA_FACT_MODEL=gemma3:4b
TRIPPROOF_OLLAMA_FACT_TIMEOUT_SECONDS=20.0

# RAG retrieval 조정값
TRIPPROOF_RAG_TOP_K=3
TRIPPROOF_RAG_SIMILARITY_THRESHOLD=0.0
